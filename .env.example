# ─────────────────────────────────────────────────────────────────────────────
# F1Forge Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it's already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5001
CLIENT_URL=http://localhost:5173

# JWT — generate a strong random secret for production
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex
JWT_EXPIRES_IN=7d

# ─── AI Provider (powers Assistant, Cover Letters, Resume, Interviews) ───────
# DEFAULT: Groq — a FREE, OpenAI-compatible inference API (Llama 3.3 70B).
#   1. Sign up free at https://console.groq.com  (no credit card)
#   2. Create an API key
#   3. Set GROQ_API_KEY below — done. Real AI, $0 cost.
#
# This key lives ONLY in your server/host env. `.env` is gitignored, so it is
# NEVER pushed to GitHub. Set it in your host dashboard (Render / Railway / Fly /
# VPS) at deploy time. With no key at all, the app falls back to a curated
# answer bank so it still runs.
AI_PROVIDER=groq
GROQ_API_KEY=gsk_...

# ─── Practice IDE code runner (optional) ─────────────────────────────────────
# The Practice section runs DSA code. Order of providers:
#   1. Self-hosted Piston (set PISTON_URL) — unlimited, free, all languages. RECOMMENDED.
#      docker-compose includes a `piston` service → PISTON_URL=http://piston:2000
#   2. Wandbox public API — works with no setup (best-effort, may be rate-limited).
#   3. JavaScript always runs in-browser as a final fallback.
# PISTON_URL=http://localhost:2000
# Optional overrides (sensible per-provider defaults applied when blank):
# AI_MODEL=llama-3.3-70b-versatile
# AI_BASE_URL=https://api.groq.com/openai/v1

# Optional: use OpenAI instead (set AI_PROVIDER=openai). Costs money.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── RapidAPI / JSearch (Required for live job listings) ─────────────────────
# 1. Sign up free at https://rapidapi.com
# 2. Subscribe to JSearch: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# 3. Free tier: 500 requests/month — enough for daily use
# Without this, jobs fall back to a curated list of 50 top positions.
RAPIDAPI_KEY=your_rapidapi_key_here

# ─── Google OAuth (Optional — enables "Sign in with Google") ─────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback

# ─── SendGrid (Optional — enables email reminders) ───────────────────────────
# https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ─── AWS S3 (Optional — enables resume file upload storage) ──────────────────
# https://console.aws.amazon.com/iam
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=f1forge-resumes

# ─── Persistence (optional but recommended for production) ───────────────────
# Without DATABASE_URL the app stores data in a local JSON file (resets on
# redeploy). Set a Postgres URL (Render/Neon/Supabase) to persist user data.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── Admin panel access ──────────────────────────────────────────────────────
# Comma-separated emails allowed into the /admin dashboard.
# ADMIN_EMAILS=you@example.com

# Note: the Practice IDE runs Python/Java/C++ via Judge0 — subscribe (free) to
# "Judge0 CE" on RapidAPI with your RAPIDAPI_KEY. JavaScript always runs in-browser.
